<UserControl x:Class="GitContextSwitcher.UI.Views.PreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="600"
             xmlns:local="clr-namespace:GitContextSwitcher.UI.Views;assembly=GitContextSwitcher.UI">
    <Border BorderBrush="#FFDDDDDD" BorderThickness="1" Padding="6" Background="#FFF">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock Text="Preview" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#EEE" BorderThickness="1" Padding="4">
                    <TreeView ItemsSource="{Binding FileTree}" SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                          <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <!-- Use the same glyph + colored-foreground approach as the PendingTreeView -->
                            <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                              <TextBlock Text="{Binding DisplayIcon}" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{Binding IconBrush}" />
                              <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" ToolTip="{Binding ToolTipText}" />
                            </StackPanel>
                          </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <Border Grid.Column="2" BorderBrush="#EEE" BorderThickness="1" Padding="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding FilePreview}" FontFamily="Consolas" FontSize="12" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" />
                        </ScrollViewer>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="(truncated)" Foreground="DarkOrange" Visibility="{Binding IsTruncated, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,6,8,0" />
                            <TextBlock Text="(context.json truncated)" Foreground="DarkOrange" Visibility="{Binding ContextJsonTruncated, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,6,8,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
