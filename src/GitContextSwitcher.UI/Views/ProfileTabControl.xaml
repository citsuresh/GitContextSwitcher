<UserControl x:Class="GitContextSwitcher.UI.Views.ProfileTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:GitContextSwitcher.UI.Views;assembly=GitContextSwitcher.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:GitContextSwitcher.UI.Views;assembly=GitContextSwitcher.UI"

             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             MinWidth="1000">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- ObjectToBoolConverter removed from XAML; selection enable-binding handled in code-behind -->
            <!-- Unified style for the bordered expander sections so collapsed spacing is consistent -->
            <Style x:Key="SectionBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="#FFDDDDDD" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Margin" Value="0,8,0,4" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Padding="10">
        <Grid>
            <!-- Content grid allows overlaying a loading panel -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
            <!-- First line: profile name and edit button aligned to the right -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Name area (left) - show read-only or inline editor -->
                <Grid Grid.Column="0">
                    <!-- Read-only view -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Visibility="{Binding IsEditingName, Converter={StaticResource InverseBoolToVisibilityConverter}}" VerticalAlignment="Center" />
                        <!-- Loading spinner next to name when profile is loading -->
                        <Border Width="16" Height="16" Margin="8,0,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Viewbox Stretch="Uniform">
                                <Canvas Width="16" Height="16">
                                    <Ellipse Width="12" Height="12" Stroke="Gray" StrokeThickness="2" Opacity="0.3" Canvas.Left="2" Canvas.Top="2" />
                                    <Path Data="M8,2 A6,6 0 1 1 7.99,2" Stroke="DodgerBlue" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </Path.RenderTransform>
                                        <Path.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Path.Triggers>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                        </Border>
            <!-- History expander was moved here in code; it will be rendered inside the scroll content below. -->
                    </StackPanel>

                    <!-- Inline edit view -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditingName, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBox x:Name="NameEditor" Width="340" Text="{Binding TempName, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="NameEditor_PreviewKeyDown" />
                        <Button x:Name="SaveIcon" Style="{StaticResource InlineIconButtonStyle}" Content="✔" Margin="6,0,0,0" Command="{Binding SaveNameCommand}" ToolTip="Save" />
                        <Button x:Name="CancelIcon" Style="{StaticResource InlineDangerIconButtonStyle}" Content="✖" Margin="6,0,0,0" Command="{Binding CancelEditNameCommand}" ToolTip="Cancel" />
                    </StackPanel>
                </Grid>

                <!-- Save and Edit buttons (right) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Save button shown when profile has unsaved changes -->
                    <Button Content="💾" Width="32" Height="24" Margin="0,0,6,0" ToolTip="Save profile" Command="{Binding SaveCommand}" Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibilityConverter}}" Style="{StaticResource HeaderIconButtonStyle}" />
                    <Button Content="✎" Width="28" Height="24" Margin="0,0,0,0" ToolTip="Edit profile name" Command="{Binding EditNameCommand}" Visibility="{Binding IsEditingName, Converter={StaticResource InverseBoolToVisibilityConverter}}" Style="{StaticResource HeaderIconButtonStyle}" />
                </StackPanel>
            </Grid>

            <!-- Inline save status (errors or transient messages) -->
            <Grid Margin="0,4,0,0">
                <TextBlock Text="{Binding SaveStatus}" Foreground="DarkRed" FontSize="12" Visibility="{Binding SaveStatus, Converter={StaticResource StringToVisibilityConverter}}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Width="16" Height="16" Margin="6,0,0,0" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="16" Height="16">
                                <Ellipse Width="12" Height="12" Stroke="Gray" StrokeThickness="2" Opacity="0.3" Canvas.Left="2" Canvas.Top="2" />
                                <Path Data="M8,2 A6,6 0 1 1 7.99,2" Stroke="DodgerBlue" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Repository path and pick button -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Repository:" FontWeight="SemiBold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RepoPath}" Foreground="Gray" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="📁" Width="28" Height="22" Margin="8,0,0,0" ToolTip="Pick repository" Command="{Binding PickRepositoryCommand}" Style="{StaticResource InlineIconButtonStyle}" />
            </Grid>

            <!-- Repository details collapsible card (populated by control) -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <Expander x:Name="RepoExpander" Header="Repository details" IsExpanded="False" Visibility="Visible">
                    <Border Padding="6">
                        <!-- Host for the RepoInfoControl (created by code-behind) -->
                        <Border x:Name="RepoInfoHost" Padding="6" />
                    </Border>
                </Expander>
            </Border>

            <!-- History expander moved to end of the content (rendered after pending changes) -->

            <!-- Notes section shown below repository details as an expander -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <Expander x:Name="NotesExpander">
                    <Expander.Header>
                        <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                    </Expander.Header>
                    <Border Padding="6" Background="#FFF" BorderThickness="1" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Overlapping notes display/editor area -->
                        <Grid Grid.Column="0">
                            <!-- Read-only notes wrapped in ScrollViewer to show scrollbars when content large -->
                            <!-- Fixed-height read-only viewer (approx. 10 rows) with scrollbar when content exceeds -->
                            <ScrollViewer x:Name="NotesViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Height="100" Visibility="{Binding IsEditingNotes, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock TextWrapping="Wrap" Text="{Binding Notes}" Foreground="Black" Margin="0,0,6,0" />
                            </ScrollViewer>

                            <!-- Inline editor for notes -->
                            <Grid Visibility="{Binding IsEditingNotes, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Editor matches the fixed viewer height so the UI doesn't jump when entering edit mode -->
                                <TextBox Grid.Column="0" x:Name="NotesEditor" Text="{Binding TempNotes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="{Binding ElementName=NotesViewer, Path=Height}" />
                                <Button Grid.Column="1" Style="{StaticResource InlineIconButtonStyle}" Content="✔" Margin="6,0,0,0" Command="{Binding SaveNotesCommand}" ToolTip="Save" />
                                <Button Grid.Column="2" Style="{StaticResource InlineDangerIconButtonStyle}" Content="✖" Margin="6,0,0,0" Command="{Binding CancelEditNotesCommand}" ToolTip="Cancel" />
                            </Grid>
                        </Grid>

                        <!-- Edit notes button -->
                        <Button Grid.Column="1" Content="✎" Width="28" Height="24" Margin="8,0,0,0" ToolTip="Edit notes" Command="{Binding EditNotesCommand}" Style="{StaticResource HeaderIconButtonStyle}" Visibility="{Binding IsEditingNotes, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    </Grid>
                </Border>
                </Expander>
            </Border>

            <!-- Pending changes tree view as an expander (expanded by default) -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <Expander x:Name="PendingExpander">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Folder icon rendered as a vector for crisp DPI scaling -->
                        <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#FF666666" Data="M3,7 L9,7 L11,9 L21,9 C21.552,9 22,9.448 22,10 L22,18 C22,19.105 21.105,20 20,20 L4,20 C2.895,20 2,19.105 2,18 L2,8 C2,7.448 2.448,7 3,7 Z" />
                            </Canvas>
                        </Viewbox>

                        <!-- Title -->
                        <TextBlock Text="Pending changes" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />

                        <!-- Total count badge -->
                        <Border Style="{StaticResource CountBadgeStyle}">
                            <TextBlock Text="{Binding PendingChangesCount}" Style="{StaticResource CountBadgeTextStyle}" />
                        </Border>

                        <!-- Staged / Unstaged badges -->
                        <Border Style="{StaticResource CountBadgeStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Staged:" Foreground="Gray" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding StagedChangesCount}" Style="{StaticResource CountBadgeTextStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CountBadgeStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Unstaged:" Foreground="Gray" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding UnstagedChangesCount}" Style="{StaticResource CountBadgeTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander.Header>

                <Border Padding="6" Background="#FFF" BorderThickness="1" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid>
                                <TreeView x:Name="PendingTreeView" ItemsSource="{Binding FileTree}" Height="200" Visibility="{Binding HasPendingChanges, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Padding" Value="4,2,2,2" />
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                                            <TextBlock Text="{Binding DisplayIcon}" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{Binding IconBrush}" />
                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" ToolTip="{Binding ToolTipText}" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                                <TextBlock Text="No pending changes" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasPendingChanges, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                                <!-- Overlay spinner shown while VM.IsLoading true -->
                                <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Viewbox Width="32" Height="32">
                                                <Canvas Width="32" Height="32">
                                                    <Ellipse Width="24" Height="24" Stroke="Gray" StrokeThickness="2" Opacity="0.3" Canvas.Left="4" Canvas.Top="4" />
                                                    <Path Data="M16,4 A12,12 0 1 1 15.99,4" Stroke="DodgerBlue" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" />
                                                        </Path.RenderTransform>
                                                        <Path.Triggers>
                                                            <EventTrigger RoutedEvent="Loaded">
                                                                <BeginStoryboard>
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Path.Triggers>
                                                    </Path>
                                                </Canvas>
                                            </Viewbox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                            <!-- Refresh icon button -->
                            <Button Command="{Binding RefreshFilesCommand}" ToolTip="Refresh" Style="{StaticResource InlineIconButtonStyle}" Width="28" Height="24">
                                <TextBlock Text="⟳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    </Border>
                </Expander>
            </Border>
            <!-- Files placeholder removed per request -->

            <!-- History expander: placed at bottom of the profile content -->
            <!-- Saved Work Contexts expander: new UI skeleton -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <Expander x:Name="SavedContextsExpander">
                    <Expander.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Saved Work Contexts" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                        <!-- Saved contexts count badge (mirrors Pending changes badge) -->
                        <Border Style="{StaticResource CountBadgeStyle}" Margin="8,0,0,0">
                            <TextBlock Text="{Binding SavedContexts.Count}" Style="{StaticResource CountBadgeTextStyle}" />
                        </Border>
                    </StackPanel>
                </Expander.Header>

                <Border Padding="4" Background="#FFF" BorderThickness="1" Margin="0,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Notification / status line -->
                        <Border Grid.Row="0" Background="#00FFFFFF" Padding="4" Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding NotificationMessage}" Foreground="Black" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="✖" Width="20" Height="20" Margin="6,0,0,0" Command="{Binding ClearNotificationCommand}" ToolTip="Clear" />
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right">
                            <Button x:Name="OpenContextFolderButton" Width="160" Height="24" Style="{StaticResource InlineIconButtonStyle}" ToolTip="Open selected context folder in Explorer" Margin="0,-6,6,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Open Context Folder" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="DeleteSavedContextButton" Width="196" Height="24" Style="{StaticResource InlineDangerIconButtonStyle}" ToolTip="Delete selected context" Margin="0,-6,6,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🗑" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Delete Selected Work Context" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="SaveContextButton" Command="{Binding SaveContextCommand}" Style="{StaticResource InlineIconButtonStyle}" Width="152" Height="24" Margin="0,-6,6,0" ToolTip="Save current context">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Save Current Context" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="RefreshSavedContextsButton" Command="{Binding RefreshSavedContextsCommand}" Style="{StaticResource InlineIconButtonStyle}" Width="28" Height="24"  Margin="0,-2,0,0" ToolTip="Refresh" >
                                <TextBlock Text="⟳" FontSize="20" HorizontalAlignment="Center"  Margin="0,-8,0,0" VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <DataGrid x:Name="SavedContextsGrid" ItemsSource="{Binding SavedContexts}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"  CanUserResizeColumns="True" CanUserReorderColumns="True"  HeadersVisibility="Column" SelectionMode="Single" RowHeaderWidth="0" MinHeight="80" MaxHeight="240" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
                                <DataGrid.Columns>
                                    <DataGridTextColumn CanUserResize="True" Header="Created" Binding="{Binding CreatedAt, StringFormat={}{0:G}}" Width="160" MinWidth="140" />
                                    <DataGridTextColumn CanUserResize="True" Header="ID" Binding="{Binding Id}" MinWidth="260" />
                                    <DataGridTemplateColumn CanUserResize="True" Header="Description" MinWidth="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Description}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolderMissing}" Value="True">
                                                                    <Setter Property="Text" Value="Missing saved context folder" />
                                                                    <Setter Property="Foreground" Value="Red" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn CanUserResize="True" Header="Files" Binding="{Binding FileCount}" Width="80" MinWidth="60" />
                                    <DataGridTextColumn CanUserResize="True" Header="Branch" Binding="{Binding HeadBranch}" Width="180" MinWidth="120" />
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFolderMissing}" Value="True">
                                            <!-- Keep background unchanged; text coloring handled in cell template -->
                                            <Setter Property="Background" Value="Transparent" />
                                        </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </Grid>

                        <!-- Overlay while saved contexts are loading: covers entire Saved Work Contexts section -->
                        <Border Background="#80FFFFFF" Grid.RowSpan="3" Visibility="{Binding IsSavedContextsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="1000">
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Viewbox Width="32" Height="32">
                                        <Canvas Width="32" Height="32">
                                            <Ellipse Width="24" Height="24" Stroke="Gray" StrokeThickness="2" Opacity="0.3" Canvas.Left="4" Canvas.Top="4" />
                                            <Path Data="M16,4 A12,12 0 1 1 15.99,4" Stroke="DodgerBlue" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0" />
                                                </Path.RenderTransform>
                                                <Path.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Path.Triggers>
                                            </Path>
                                        </Canvas>
                                    </Viewbox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                </Expander>
            </Border>
            <Border Style="{StaticResource SectionBorderStyle}">
                <Expander x:Name="HistoryExpander">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="History" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                        <Border Style="{StaticResource CountBadgeStyle}" Margin="8,0,0,0">
                            <TextBlock Text="{Binding HistoryCountBadge, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource CountBadgeTextStyle}" />
                        </Border>
                    </StackPanel>
                </Expander.Header>

                <Border Padding="4" Background="#FFF" BorderThickness="1" Margin="0,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Right">
                            <Button Command="{Binding RefreshHistoryCommand}" Style="{StaticResource InlineIconButtonStyle}" Width="28" Height="20" Margin="0,-2,0,0" ToolTip="Refresh history">
                                <TextBlock Text="⟳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-8,0,0" />
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <!-- Display history entries in a compact DataGrid for easier scanning and copy/paste -->
                            <DataGrid ItemsSource="{Binding HistoryEntries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      RowHeaderWidth="0"
                                      MinHeight="80"
                                      MaxHeight="240"
                                      Margin="0"
                                      VerticalAlignment="Top"
                                      CanUserResizeColumns="True"
                                      CanUserReorderColumns="True"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn CanUserResize="True" Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:G}}" Width="180" MinWidth="140" />
                                    <DataGridTextColumn CanUserResize="True" Header="Action" Binding="{Binding Action}" Width="160" MinWidth="120" />
                                    <DataGridTemplateColumn CanUserResize="True" Header="Notes" Width="*" MinWidth="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Notes}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn CanUserResize="True" Header="User" Binding="{Binding User}" Width="140" MinWidth="100" />
                                    <DataGridTemplateColumn CanUserResize="True" Header="Error" Width="220" MinWidth="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Error}" Foreground="DarkRed" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Overlay while history is loading -->
                            <Border Background="#80FFFFFF" Visibility="{Binding IsHistoryLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Viewbox Width="32" Height="32">
                                            <Canvas Width="32" Height="32">
                                                <Ellipse Width="24" Height="24" Stroke="Gray" StrokeThickness="2" Opacity="0.3" Canvas.Left="4" Canvas.Top="4" />
                                                <Path Data="M16,4 A12,12 0 1 1 15.99,4" Stroke="DodgerBlue" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
