<Window x:Class="GitContextSwitcher.UI.Views.RepositoryPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Repository" Height="360" Width="560" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Repository folder:" Grid.Row="0" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBox x:Name="PathBox" Width="360" />
            <Button Content="Browse..." Margin="8,0,0,0" Width="80" Click="Browse_Click" />
            <Button x:Name="RefreshRepoButton" Content="⟳" Width="36" Height="28" Margin="8,0,0,0" ToolTip="Refresh discovery" Click="RefreshRepoButton_Click" />
        </StackPanel>

        <!-- Details panel -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="8">
            <StackPanel>
                <TextBlock x:Name="RepoStatusText" Text="" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <StackPanel Width="280">
                        <TextBlock Text="Name:" FontWeight="Bold" />
                        <TextBlock x:Name="RepoName" Text="-" />
                        <TextBlock Text="Branch:" FontWeight="Bold" Margin="0,8,0,0" />
                        <TextBlock x:Name="RepoBranch" Text="-" />
                        <TextBlock Text="Last commit:" FontWeight="Bold" Margin="0,8,0,0" />
                        <TextBlock x:Name="RepoHead" Text="-" />
                    </StackPanel>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Commits:" FontWeight="Bold" />
                        <TextBlock x:Name="RepoCommits" Text="-" />
                        <TextBlock Text="Status:" FontWeight="Bold" Margin="0,8,0,0" />
                        <TextBlock x:Name="RepoDirty" Text="-" />
                        <TextBlock Text="Remotes:" FontWeight="Bold" Margin="0,8,0,0" />
                        <TextBlock x:Name="RepoRemotes" Text="-" TextWrapping="Wrap" Width="220" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click" IsEnabled="False" />
            <Button Content="Cancel" Width="80" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
