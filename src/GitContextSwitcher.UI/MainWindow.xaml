<Window x:Class="GitContextSwitcher.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitContextSwitcher.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
    <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="LightGray">
        <MenuItem Header="File">
            <!-- Bind New Profile to AddProfileCommand in MainViewModel -->
            <MenuItem Header="New Profile" Command="{Binding AddProfileCommand}"/>
            <MenuItem Header="Close All" Command="{Binding CloseAllCommand}"/>
            <!-- Exit handled in code-behind to close the window - placed last -->
            <MenuItem Header="Exit" Click="ExitMenu_Click"/>
        </MenuItem>
        <MenuItem Header="Help">
            <!-- About shows a simple dialog -->
            <MenuItem Header="About" Click="AboutMenu_Click"/>
        </MenuItem>
    </Menu>
    <!-- Tab area -->
    <Grid Grid.Row="1">
        <!-- Tab Control bound to profiles with custom header template and control template -->
        <TabControl x:Name="ProfileTabs" Margin="5" ItemsSource="{Binding OpenProfiles}" SelectedItem="{Binding SelectedProfile}">
            <TabControl.Resources>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Header area: left scroll button | scrolling tab headers | right controls (right scroll, add, dropdown) -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="PART_ScrollLeft" Content="◀" Style="{StaticResource HeaderIconButtonStyle}" Margin="0,0,4,0" Click="ScrollLeft_Click" ToolTip="Scroll left" Grid.Column="0" VerticalAlignment="Center"/>

                                        <ScrollViewer x:Name="PART_TabScrollViewer" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" CanContentScroll="False" Focusable="False" Grid.Column="1">
                                            <TabPanel x:Name="HeaderPanel" IsItemsHost="True" Background="Transparent" />
                                        </ScrollViewer>

                                        <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center" Margin="4,0,8,0" HorizontalAlignment="Right">
                                            <Button x:Name="PART_ScrollRight" Content="▶" Style="{StaticResource HeaderIconButtonStyle}" Margin="0,0,8,0" Click="ScrollRight_Click" ToolTip="Scroll right" />
                                            <Button Command="{Binding AddProfileCommand}" Content="+" Style="{StaticResource HeaderFlatAddButton}" Margin="0,0,8,0" ToolTip="Add profile" />
                                            <!-- Use styled filled toggle button; remove inline Background/Content so style colors and triangle template apply -->
                                            <ToggleButton x:Name="PART_ProfileDropdownToggle" Width="28" Height="24" ToolTip="Open profiles list" Style="{StaticResource HeaderIconToggleStyle}" />

                                            <Popup IsOpen="{Binding IsChecked, ElementName=PART_ProfileDropdownToggle}" PlacementTarget="{Binding ElementName=PART_ProfileDropdownToggle}" StaysOpen="False">
                                                <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                                                    <StackPanel>
                                                        <ItemsControl ItemsSource="{Binding ClosedProfiles}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="{Binding Name}" Padding="8" Command="{Binding DataContext.OpenProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>

                                            <!-- Overflow: list all profiles -->
                                            <Popup Placement="Bottom" PlacementTarget="{Binding RelativeSource={RelativeSource Self}}">
                                                <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                                                    <StackPanel>
                                                        <ItemsControl ItemsSource="{Binding Profiles}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="{Binding Name}" Padding="8" Command="{Binding DataContext.OpenProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                    </Grid>

                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding Name}" Margin="6,2,8,0" FontWeight="Bold"/>
                            <TextBlock Text="{Binding RepoPath}" Margin="6,0,8,2" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1" Margin="6,6,0,0" Command="{Binding DataContext.CloseProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                    IsEnabled="{Binding DataContext.CanCloseAny, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource TabCloseButtonStyle}">
                            <Viewbox Width="12" Height="12">
                                <Canvas Width="12" Height="12">
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M2,2 L10,10 M10,2 L2,10" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Border Padding="10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel>
                                    <StackPanel.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </StackPanel.Resources>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Read-only view -->
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Visibility="{Binding IsEditingName, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                                        <!-- Inline edit view -->
                                        <StackPanel Orientation="Horizontal" Grid.Column="0" Visibility="{Binding IsEditingName, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBox x:Name="NameEditor" Width="300" Text="{Binding TempName, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="NameEditor_PreviewKeyDown" />
                                            <Button x:Name="SaveIcon" Style="{StaticResource InlineIconButtonStyle}" Content="✔" Margin="6,0,0,0" Command="{Binding SaveNameCommand}" ToolTip="Save" />
                                            <Button x:Name="CancelIcon" Style="{StaticResource InlineDangerIconButtonStyle}" Content="✖" Margin="6,0,0,0" Command="{Binding CancelEditNameCommand}" ToolTip="Cancel" />
                                        </StackPanel>

                                        <!-- Edit button (shows when not editing) -->
                                        <Button Grid.Column="1" Content="✎" Width="24" Height="22" Margin="8,0,0,0" ToolTip="Edit profile name" Command="{Binding EditNameCommand}" Visibility="{Binding IsEditingName, Converter={StaticResource InverseBoolToVisibilityConverter}}" Style="{StaticResource HeaderIconButtonStyle}" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding RepoPath}" Foreground="Gray" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Files: (placeholder)" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </Grid>
</Grid>
</Window>
